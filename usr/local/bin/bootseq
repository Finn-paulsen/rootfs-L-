#!/bin/bash

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

type_text() {
    local text="$1"
    local delay="${2:-0.03}"
    for (( i=0; i<${#text}; i++ )); do
        echo -ne "${text:$i:1}"
        sleep "$delay"
    done
    echo ""
}

ok()   { echo -e "  $1 $(printf '%-28s' | tr ' ' '.')  [ ${GREEN}OK${NC} ]"; }
warn() { echo -e "  $1 $(printf '%-28s' | tr ' ' '.')  [ ${YELLOW}$2${NC} ]"; }
fail() { echo -e "  $1 $(printf '%-28s' | tr ' ' '.')  [ ${RED}FAILED${NC} ]"; }

clear
echo ""
echo -e "${BOLD}Project Hydra  —  NRF24-Gateway-01${NC}"
echo -e "RF-Hub / Data Relay Node"
echo ""
sleep 0.4

type_text "Checking hardware ..." 0.04
sleep 0.15
ok "CPU"
sleep 0.08
ok "RAM"
sleep 0.08
ok "Storage"
sleep 0.08
ok "Network interface"
sleep 0.08
ok "RF-Module (NRF24L01+)"
echo ""
sleep 0.3

type_text "Loading kernel modules ..." 0.04
sleep 0.15
ok "spi_bcm2835"
sleep 0.1
ok "rf69 / nrf24_core"
sleep 0.1
ok "net_relay_bridge"
echo ""
sleep 0.3

type_text "Checking dependencies ..." 0.04
sleep 0.15

# Python3
if command -v python3 >/dev/null 2>&1; then
    PY_VER=$(python3 --version 2>&1 | awk '{print $2}')
    echo -e "  python3 ............................  [ ${GREEN}${PY_VER}${NC} ]"
else
    fail "python3"
fi
sleep 0.1

# requests Modul
if python3 -c "import requests" 2>/dev/null; then
    ok "python3-requests"
else
    fail "python3-requests"
fi
sleep 0.1

# RF-Skript
if [ -f /home/finn/hydra/hub/send_test.py ]; then
    ok "hub/send_test.py"
else
    fail "hub/send_test.py"
fi
sleep 0.1

# SPI
if ls /dev/spidev* >/dev/null 2>&1; then
    ok "SPI interface (/dev/spidev)"
else
    warn "SPI interface" "DISABLED"
fi
echo ""
sleep 0.3

type_text "Checking network ..." 0.04
sleep 0.15
/usr/local/bin/check_backend.sh
echo ""
sleep 0.2

echo -e "${BOLD}System ready.${NC}"
echo ""
