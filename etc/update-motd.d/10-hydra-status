#!/bin/bash

# Farben definieren (Retro-Futuristisch, ähnlich Hydra CSS)
GREEN='\033[0;32m'
DARK_GREEN='\033[1;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Systeminformationen abrufen
UPTIME=$(uptime -p | cut -d " " -f 2-)
KERNEL=$(uname -r)
IP_ADDR=$(hostname -I | awk '{print $1}')

echo -e "${DARK_GREEN}#################################################################${NC}"
echo -e "${DARK_GREEN}#${NC}                                                               ${DARK_GREEN}#${NC}"
echo -e "${DARK_GREEN}#${NC}  ${GREEN}GOV-ARCHIVE INFORMATION GRID${NC}                                 ${DARK_GREEN}#${NC}"
echo -e "${DARK_GREEN}#${NC}  ${GREEN}CLASSIFIED ACCESS INTERFACE${NC}                                  ${DARK_GREEN}#${NC}"
echo -e "${DARK_GREEN}#${NC}                                                               ${DARK_GREEN}#${NC}"
echo -e "${DARK_GREEN}#################################################################${NC}"
echo ""
echo -e "${YELLOW}SYSTEM IDENTIFICATION:${NC}"
echo -e "  NODE ID:     ${GREEN}NRF24-GATEWAY-01${NC}"
echo -e "  ROLE:        ${GREEN}RF-HUB / DATA RELAY NODE${NC}"
echo -e "  UPTIME:      ${GREEN}${UPTIME}${NC}"
echo -e "  KERNEL:      ${GREEN}${KERNEL}${NC}"
echo -e "  NETWORK:     ${GREEN}${IP_ADDR}${NC}"
echo ""
echo -e "${YELLOW}HARDWARE STATUS:${NC}"
echo -e "  CPU:                 [ ${GREEN}OK${NC} ]"
echo -e "  RAM:                 [ ${GREEN}OK${NC} ]"
echo -e "  STORAGE:             [ ${GREEN}OK${NC} ]"
echo -e "  NETWORK INTERFACE:   [ ${GREEN}OK${NC} ]"
echo -e "  RF-MODULE (NRF24):   [ ${GREEN}SYNC ACTIVE${NC} ]"
echo ""
echo -e "${YELLOW}SECURITY LAYER:${NC}"
echo -e "  ENCRYPTION:          [ ${GREEN}ACTIVE${NC} ]"
echo -e "  AUTH CHANNEL:        [ ${GREEN}SECURE${NC} ]"
echo -e "  INTEGRITY CHECK:     [ ${GREEN}PASSED${NC} ]"
echo ""
echo -e "${YELLOW}NETWORK STATUS:${NC}"
# Backend Check aufrufen
/usr/local/bin/check_backend.sh
echo ""
echo -e "${DARK_GREEN}=================================================================${NC}"
echo -e "${GREEN}SYSTEM READY. TYPE COMMAND TO PROCEED.${NC}"
